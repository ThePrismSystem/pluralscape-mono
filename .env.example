# Pluralscape development ports
API_PORT=10045
MOBILE_WEB_PORT=10098

# Test infrastructure ports (used by integration tests for Docker containers)
TEST_MINIO_PORT=10943
TEST_VALKEY_PORT=10944

# Deployment mode: "self-hosted" (default) or "hosted" for cloud/managed deployments.
# In hosted mode, plaintext search_index is disabled (see ADR 018).
DEPLOYMENT_MODE=self-hosted

# Database
DB_DIALECT=pg
DATABASE_URL=
DATABASE_PATH=pluralscape.db
# SQLCipher encryption key (hex-encoded, exactly 64 chars for AES-256). Required in production.
# SQLITE_ENCRYPTION_KEY=

# Auth
# Email hash pepper: 64-character hex string (32 bytes) used as BLAKE2b key for email hashing.
# Required for auth. Losing this value breaks all email lookups — back it up securely.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
EMAIL_HASH_PEPPER=

# API key HMAC key: 64-character hex string (32 bytes) used as HMAC-SHA256 key for
# hashing API key tokens before storage. Required in production for defense-in-depth.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
API_KEY_HMAC_KEY=

# Email encryption key: 64-character hex string (32 bytes) used for XChaCha20-Poly1305
# encryption of stored email addresses. Required in production for email privacy.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=

# Webhook payload encryption key: 64-character hex string (32 bytes) used for XChaCha20-Poly1305
# encryption of webhook delivery payloads at rest. Required — webhook payloads must be encrypted.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
WEBHOOK_PAYLOAD_ENCRYPTION_KEY=

# Crowdin i18n integration
# Personal access token with project-level permissions (translations + config).
# Create at https://crowdin.com/settings#api-key
CROWDIN_PERSONAL_TOKEN=
# Numeric project ID from https://crowdin.com/project/<slug>/settings
CROWDIN_PROJECT_ID=

# DeepL Free API key for MT pre-translation (de, es, fr, it, ja, ko, nl, pt-BR, ru, zh-Hans).
# Sign up at https://www.deepl.com/pro-api (Free plan: 500k chars/month).
DEEPL_API_KEY=

# Google Translate credentials — set one of these.
# Preferred for CI (the secret is the raw JSON blob):
GOOGLE_TRANSLATE_SERVICE_ACCOUNT_JSON=
# Preferred for local dev (path to a service-account file):
GOOGLE_APPLICATION_CREDENTIALS=
