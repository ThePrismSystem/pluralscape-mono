# Pluralscape development ports
API_PORT=10045
MOBILE_WEB_PORT=10098

# Deployment mode: "self-hosted" (default) or "hosted" for cloud/managed deployments.
# In hosted mode, plaintext search_index is disabled (see ADR 018).
DEPLOYMENT_MODE=self-hosted

# Database
DB_DIALECT=pg
DATABASE_URL=
DATABASE_PATH=pluralscape.db
# SQLCipher encryption key (hex-encoded, exactly 64 chars for AES-256). Required in production.
# SQLITE_ENCRYPTION_KEY=

# Auth
# Email hash pepper: 64-character hex string (32 bytes) used as BLAKE2b key for email hashing.
# Required for auth. Losing this value breaks all email lookups — back it up securely.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
EMAIL_HASH_PEPPER=
