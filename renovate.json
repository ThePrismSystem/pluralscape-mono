{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["on monday"],
  "labels": ["domain: infra"],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies (patch/minor)"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "groupName": "GitHub Actions"
    },
    {
      "matchPackageNames": ["fast-xml-parser"],
      "allowedVersions": "~5.5.7",
      "description": "Pinned: 5.7.x rejects &#xD; entities in S3 XML responses, breaking @aws-sdk/xml-builder. Revisit when upstream regression is fixed."
    }
  ]
}
