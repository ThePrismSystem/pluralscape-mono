{
  "expo": {
    "name": "Pluralscape",
    "slug": "pluralscape",
    "version": "0.0.1",
    "scheme": "pluralscape",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "platforms": ["ios", "android", "web"],
    "plugins": [
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    }
  }
}
