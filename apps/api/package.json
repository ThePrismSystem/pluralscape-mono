{
  "name": "@pluralscape/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "bundle": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "echo 'Run tests from the monorepo root: pnpm vitest run --project api' && exit 1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --fix --max-warnings 0 .",
    "clean": "rm -rf dist",
    "trpc:parity": "tsx scripts/check-trpc-parity.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@pluralscape/crypto": "workspace:*",
    "@pluralscape/db": "workspace:*",
    "@pluralscape/email": "workspace:*",
    "@pluralscape/queue": "workspace:^",
    "@pluralscape/storage": "workspace:*",
    "@pluralscape/sync": "workspace:*",
    "@pluralscape/types": "workspace:*",
    "@pluralscape/validation": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "@trpc/server": "11.16.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.12",
    "pino": "^10.0.0",
    "postgres": "^3.4.9",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@pluralscape/eslint-config": "workspace:*",
    "@pluralscape/test-utils": "workspace:*",
    "@pluralscape/tsconfig": "workspace:*",
    "@types/bun": "^1.2.4",
    "eslint": "^10.2.0",
    "typescript": "^6.0.0"
  }
}
