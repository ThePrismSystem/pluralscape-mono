{
  "name": "@pluralscape/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "echo 'Run tests from the monorepo root: pnpm vitest run --project api' && exit 1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --fix --max-warnings 0 .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@pluralscape/crypto": "workspace:*",
    "@pluralscape/db": "workspace:*",
    "@pluralscape/queue": "workspace:^",
    "@pluralscape/storage": "workspace:*",
    "@pluralscape/sync": "workspace:*",
    "@pluralscape/types": "workspace:*",
    "@pluralscape/validation": "workspace:*",
    "@trpc/server": "11.13.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "postgres": "^3.4.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pluralscape/eslint-config": "workspace:*",
    "@pluralscape/test-utils": "workspace:*",
    "@pluralscape/tsconfig": "workspace:*",
    "@types/bun": "^1.2.4",
    "eslint": "^10.0.3",
    "typescript": "^5.7.3"
  }
}
