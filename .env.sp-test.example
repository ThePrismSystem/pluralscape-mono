# Example environment file for the SP seed script (scripts/sp-seed).
#
# Copy this file to `.env.sp-test` (gitignored) and fill in real values
# before running `pnpm seed:sp-test`. The script will populate the
# SP_TEST_<MODE>_API_KEY and SP_TEST_<MODE>_SYSTEM_ID fields on its first
# successful run — you do not need to fill those in by hand.
#
# Email addresses can also be passed on the CLI:
#   pnpm seed:sp-test --minimal-email=<m> --adversarial-email=<a>
# CLI values override anything in this file.

# Override the SP API base URL (optional; defaults to https://api.apparyllis.com)
#SP_API_BASE_URL=https://api.apparyllis.com

# --- minimal mode ---
SP_TEST_MINIMAL_EMAIL=minimal-seed@example.com
# If omitted, the script falls back to SP_TEST_PASSWORD env var, then to a
# hardcoded default. Set this if you want a deterministic per-mode password.
#SP_TEST_MINIMAL_PASSWORD=
# Populated by the script after first successful bootstrap — do not edit.
#SP_TEST_MINIMAL_API_KEY=
#SP_TEST_MINIMAL_SYSTEM_ID=

# --- adversarial mode ---
SP_TEST_ADVERSARIAL_EMAIL=adversarial-seed@example.com
#SP_TEST_ADVERSARIAL_PASSWORD=
#SP_TEST_ADVERSARIAL_API_KEY=
#SP_TEST_ADVERSARIAL_SYSTEM_ID=
