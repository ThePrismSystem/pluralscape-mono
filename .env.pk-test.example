# Example environment file for the PK seed script (scripts/pk-seed).
#
# Copy this file to `.env.pk-test` (gitignored) and fill in real values
# before running `pnpm seed:pk-test`. PK does not support programmatic
# system creation — you must create systems manually via the PK Discord
# bot and supply the tokens here.

# Set to "true" to enable live PK API E2E tests
#PK_TEST_LIVE_API=true

# Override the PK API base URL (optional; defaults to https://api.pluralkit.me)
#PK_API_BASE_URL=https://api.pluralkit.me

# --- minimal mode ---
# System token from `pk;token` in the PK Discord bot
PK_TOKEN_MINIMAL=

# --- adversarial mode ---
PK_TOKEN_ADVERSARIAL=
