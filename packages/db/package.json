{
  "name": "@pluralscape/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./pg": "./src/schema/pg/index.ts",
    "./sqlite": "./src/schema/sqlite/index.ts",
    "./test-helpers/pg-helpers": "./src/__tests__/helpers/pg-helpers.ts"
  },
  "dependencies": {
    "@pluralscape/crypto": "workspace:*",
    "@pluralscape/types": "workspace:*",
    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.6.2",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@pluralscape/eslint-config": "workspace:*",
    "@pluralscape/test-utils": "workspace:*",
    "@pluralscape/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --fix --max-warnings 0 .",
    "db:generate:pg": "tsx node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.pg.ts",
    "db:generate:sqlite": "tsx node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.sqlite.ts",
    "db:apply-rls": "tsx scripts/apply-rls.ts"
  }
}
